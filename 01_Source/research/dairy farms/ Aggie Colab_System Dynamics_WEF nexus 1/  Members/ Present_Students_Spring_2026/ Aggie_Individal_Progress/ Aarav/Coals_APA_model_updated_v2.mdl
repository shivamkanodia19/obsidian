{UTF-8}
Number of Cows=
	100
	~	cows
	~	Hypothetical lactating dairy herd size.	|

Milk production rate=
	Number of Cows*21.5
	~	kg/day
	~	Avg lactating cow produces 21.5 kg milk/day (US avg ~23000 lbs/yr).	|

Water Usage rate=
	Number of Cows*4500
	~	liters/month
	~	Lactating cow drinks ~150 L/day x 30 days = 4500 L/cow/month.	|

Feed Consumption rate=
	Number of Cows*750
	~	kg DM/month
	~	Lactating cow requires ~25 kg DM/day TMR x 30 days = 750 kg/cow/month.	|

Energy Consumption rate=
	Number of Cows*65
	~	kWh/month
	~	Dairy farm energy use ~65 kWh/cow/month. 100 cows = 6500 kWh/month.	|

Manure Production rate=
	Number of Cows*500
	~	kg/month
	~	Lactating cow produces ~68 kg wet manure/day. Monthly ~500 kg DM/cow.	|

Urine production rate=
	Number of Cows*120
	~	liters/month
	~	Cows produce ~4 L urine/day. Monthly ~120 L/cow.	|

Biogas Production rate=
	Manure storage*0.025
	~	m3 CH4/month
	~	Anaerobic digestion: ~25 L biogas per kg VS manure. CH4 fraction 60%.	|

Solar generation rate=
	850
	~	kWh/month
	~	100 kW solar array. TX avg 5.5 peak sun hrs/day x 30 = 850 kWh/month.	|

Precipitation rate=
	75
	~	mm/month
	~	College Station TX avg precipitation ~900 mm/yr = 75 mm/month (NOAA).	|

recharge rate=
	15
	~	mm/month
	~	~20% of precipitation recharges groundwater = 15 mm/month.	|

Nutrient loss=
	Feed domain*0.05
	~	kg N/month
	~	~5% of feed nutrients lost via leaching or volatilization monthly.	|

Feed growth rate=
	Soil Nutrient*0.3
	~	kg DM/month
	~	Forage growth proportional to soil N. Coeff 0.3 from bermudagrass yield data.	|

Manure application rate=
	Manure storage*0.1
	~	kg/month
	~	10% of stored manure applied to fields monthly (agronomic loading rate).	|

Treatment rate=
	Water domain*0.15
	~	liters/month
	~	15% of water domain treated and recycled monthly.	|

Water recycling efficiency=
	0.75
	~	dimensionless
	~	75% of treated wastewater reused on-farm (industry average).	|

Milk Yield=
	INTEG(Milk production rate, 0)
	~	kg
	~	Cumulative milk produced over simulation.	|

Urine output=
	INTEG(Urine production rate, 0)
	~	liters
	~	Cumulative urine output.	|

Hypothetical dairy herd= INTEG (
	Energy Consumption rate+Feed Consumption rate+Water Usage rate\
		-Manure Production rate-Milk production rate-Urine production rate,
	100)
	~	cows
	~	Herd mass balance stock. Initial = 100 lactating cows.	|

Manure storage= INTEG (
	Manure Production rate-Biogas Production rate-Manure application rate,
	0)
	~	kg
	~	Stored manure available for anaerobic digestion or field application.	|

Water domain= INTEG (
	Precipitation rate+recharge rate+Treatment rate-Water Usage rate,
	5000)
	~	liters
	~	Total water available to farm system. Initial = 5000 L.	|

Feed domain= INTEG (
	Feed growth rate-Feed Consumption rate+Nutrient loss,
	65000)
	~	kg DM
	~	Total feed inventory. Initial = 65000 kg DM (~2 month supply for 100 cows).	|

Energy domain= INTEG (
	Biogas Production rate+Solar generation rate-Energy Consumption rate,
	0)
	~	kWh
	~	Net energy balance. Biogas + solar minus consumption.	|

Energy Storage= INTEG (
	Solar generation rate-Energy Consumption rate,
	0)
	~	kWh
	~	Battery/grid storage from solar surplus.	|

Soil Nutrient= INTEG (
	Manure application rate-Feed growth rate,
	500)
	~	kg N
	~	Soil nitrogen pool. Initial = 500 kg N.	|

surface water= INTEG (
	Precipitation rate,
	1000)
	~	liters
	~	Surface water availability. Initial = 1000 L.	|

Ground water= INTEG (
	recharge rate,
	3000)
	~	liters
	~	Groundwater stock. Initial = 3000 L.	|

Waste water reuse= INTEG (
	Treatment rate*Water recycling efficiency,
	0)
	~	liters
	~	Wastewater recovered and reused on farm.	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

\\\---/// Sketch information - do not modify anything except names
