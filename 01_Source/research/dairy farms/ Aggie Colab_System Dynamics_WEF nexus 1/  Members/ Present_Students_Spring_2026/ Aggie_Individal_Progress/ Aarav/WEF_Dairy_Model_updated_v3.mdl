{UTF-8}
Biogas generation rate=
	manure accumulated*0.025
	~	m3 CH4/Month
	~		|

Birth rate=
	Herd Size*0.008
	~	animals/Month
	~		|

"Death/Culling rate"  = A FUNCTION OF( Herd Size) ~~|
"Death/Culling rate"=
	Herd Size*0.006
	~	animals/Month
	~		|

Energy Available= INTEG (energy demand-energy outflow,
		5000)
	~	kWh
	~		|

energy demand=
	Herd Size*65
	~	kWh/Month
	~		|

energy outflow=
	Biogas generation rate*5
	~	kWh/Month
	~		|

Feed Available= INTEG (feed production rate+Feed intake rate-Feed consumption rate,
		500000)
	~	kg DM
	~		|

Feed consumption rate=
	Herd Size*750
	~	kg DM/Month
	~		|

Feed intake rate=
	Herd Size*25
	~	kg DM/Month
	~		|

feed production rate=
	Land availability*Irrigation demand*0.5
	~	kg DM/Month
	~		|

Herd Size= INTEG (Birth rate-"Death/Culling rate",
		1000)
	~	animals
	~		|

Irrigation demand=
	Waeter Available*0.3
	~	m3/Month
	~		|

Land availability=
	500
	~	hectares
	~		|

manure accumulated=
	Herd Size*15
	~	kg VS/Month
	~		|

Milk yield=A FUNCTION OF(Milk yield,Herd Size) ~~|
Milk yield=
	Herd Size*70
	~	gallons/cow
	~		|

Power Pumping=
	Energy Available*0.05
	~	m3/Month
	~		|

Waeter Available= INTEG (water inflow+Power Pumping-water consumption rate,
		10000)
	~	m3
	~		|

water consumption rate=
	Herd Size*4.5
	~	m3/Month
	~		|

water inflow=
	750
	~	m3/Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

