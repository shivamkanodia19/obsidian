# ============================================================
# trading-bot-backend  —  environment config
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ---- Anthropic (for agent runners) -------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Kalshi ------------------------------------------------
# Demo environment: https://demo-api.kalshi.co
# Production:       https://api.elections.kalshi.com
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_API_KEY_ID=your_kalshi_key_id_here
KALSHI_PRIVATE_KEY_PATH=./certs/kalshi_private.pem
KALSHI_ENVIRONMENT=demo          # demo | production

# ---- Robinhood (read-only stub in V0) ----------------------
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_CODE=
ROBINHOOD_ENVIRONMENT=paper      # paper | live  (live disabled in V0)

# ---- Database ----------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./trading.db

# ---- Risk gate ---------------------------------------------
# Hard override — set to false to enable live trading (V2+, not V0)
ALLOW_LIVE_TRADING=false
REQUIRE_MANUAL_CONFIRMATION=true
