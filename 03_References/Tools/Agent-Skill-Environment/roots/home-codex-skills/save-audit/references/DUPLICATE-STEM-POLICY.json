{
  "redirect_markers": [
    "canonical note:",
    "stable redirect",
    "redirect stub",
    "legacy alias",
    "preferred canonical folder",
    "do not create new"
  ],
  "rules": [
    {
      "stem": "email-optimization-strategy",
      "classification": "intentional_redirect",
      "required_paths": [
        "02_Analyst/career/internships/email-optimization-strategy.md",
