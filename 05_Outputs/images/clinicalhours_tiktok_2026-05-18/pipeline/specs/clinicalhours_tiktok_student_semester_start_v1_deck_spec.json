{
  "schema_version": "clinicalhours_tiktok/deck_spec/v1",
  "spec_id": "clinicalhours_tiktok_student_semester_start_v1",
  "canonical": false,
  "lane": "student_discovery_secondary",
  "evidence_tier": "product_surface",
  "proof_access": "mixed_public_and_authenticated_preview",
  "composition_source": "composition/clinicalhours_tiktok_student_semester_start.html",
  "export_suffix": "v7semesterstart",
  "copy_audit_script": "composition/audit_clinicalhours_tiktok_copy.ps1",
  "copy_style_hard_fail": {
    "reject_if_contains": [
      "why this works",
      "better story",
      "calm close",
      "best student proof",
      "real search flow",
      "visual payoff",
      "cold traffic",
      "in-feed",
      "abstract promise"
    ],
    "reject_if_meta_marketing_language": true
  },
  "screenshot_text_hard_fail": {
    "reject_if_raw_hero_asset_matches": [
      "captures/home/clinicalhours_home_mobile_430x932_live.png",
      "captures/auth/clinicalhours_dashboard_overview_auth_live_v3.png",
      "captures/auth/clinicalhours_journal_section_auth_live_v3.png",
      "captures/auth/clinicalhours_auth_signin_card_auth_live_v3.png"
    ],
    "reject_if_empty_state_is_hero": true
  },
  "slides": [
    {
      "slide_number": 1,
      "role": "friction",
      "visible_role_label": "start",
      "headline": "Need one clear start?",
      "subtext": "Find clinical hours near you before the semester search sprawls.",
      "hero_asset": "captures/derived/clinicalhours_home_mobile_button_focus_v1.png",
      "support_assets": []
    },
    {
      "slide_number": 2,
      "role": "discovery",
      "visible_role_label": "map",
      "headline": "Start with the map.",
      "subtext": "One map is easier than reopening random pages all semester.",
      "hero_asset": "captures/derived/clinicalhours_map_focus_v1.png",
      "support_assets": []
    },
    {
      "slide_number": 3,
      "role": "simplification",
      "visible_role_label": "preview",
      "headline": "Preview one clinic first.",
      "subtext": "The list keeps the clinic, location, and next step in one view.",
      "hero_asset": "captures/derived/clinicalhours_opportunity_row_focus_v1.png",
      "support_assets": []
    },
    {
      "slide_number": 4,
      "role": "documentation_direction",
      "visible_role_label": "first log",
      "headline": "Log your first hours here.",
      "subtext": "Use one journal to log the first shift now and find it again later.",
      "hero_asset": "captures/derived/clinicalhours_journal_cta_focus_v2.png",
      "support_assets": [
        "captures/derived/clinicalhours_journal_toolbar_tile_v2.png",
        "captures/derived/clinicalhours_dashboard_welcome_panel_v1.png"
      ]
    },
    {
      "slide_number": 5,
      "role": "activation",
      "visible_role_label": "browse",
      "headline": "Browse now. Sign in later.",
      "subtext": "Browse as guest first. Sign in when you want to save or log hours.",
      "hero_asset": "captures/derived/clinicalhours_auth_guest_browse_focus_v2.png",
      "support_assets": []
    }
  ]
}
