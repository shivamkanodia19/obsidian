  "copy_audit_script": "composition/audit_clinicalhours_tiktok_copy.ps1",
  "copy_style_hard_fail": {
    "reject_if_contains": [
      "why this works",
      "better story",
      "calm close",
      "best student proof",
      "real search flow",
      "visual payoff",
      "cold traffic",
      "in-feed",
      "abstract promise"
    ],
    "reject_if_meta_marketing_language": true
  },
  "screenshot_text_hard_fail": {
    "reject_if_raw_hero_asset_matches": [
      "captures/home/clinicalhours_home_mobile_430x932_live.png",
      "captures/auth/clinicalhours_dashboard_overview_auth_live_v3.png",
      "captures/auth/clinicalhours_journal_section_auth_live_v3.png",
      "captures/auth/clinicalhours_auth_signin_card_auth_live_v3.png"
    ],
    "reject_if_empty_state_is_hero": true
  },
  "slides": [
    {
      "slide_number": 1,
      "role": "friction",
      "visible_role_label": "start",
      "headline": "Don't commit on click one.",
      "subtext": "Students want to look around before another signup wall.",
      "hero_asset": "captures/derived/clinicalhours_auth_actions_focus_v2.png",
      "support_assets": []
    },
    {
      "slide_number": 2,
      "role": "discovery",
      "visible_role_label": "guest",
      "headline": "Browse as guest first.",
      "subtext": "The account wall is not the first thing you have to clear.",
      "hero_asset": "captures/auth/clinicalhours_auth_live_2026-05-29.png",
      "support_assets": []
    },
    {
      "slide_number": 3,
      "role": "simplification",
      "visible_role_label": "map",
      "headline": "See the map before signup.",
      "subtext": "See the live map before deciding whether the account is worth it.",
      "hero_asset": "captures/derived/clinicalhours_map_focus_v1.png",
      "support_assets": [
        "captures/derived/clinicalhours_auth_guest_actions_v1.png"
      ]
    },
    {
      "slide_number": 4,
      "role": "documentation_direction",
      "visible_role_label": "ready",
      "headline": "Sign in when it actually helps.",
      "subtext": "Use the account when you want one place to explore, log, and return.",
      "hero_asset": "captures/derived/clinicalhours_dashboard_welcome_panel_v1.png",
      "support_assets": [
        "captures/derived/clinicalhours_dashboard_records_band_v1.png",
        "captures/derived/clinicalhours_journal_toolbar_tile_v2.png"
      ]
    },
    {
      "slide_number": 5,
      "role": "activation",
      "visible_role_label": "browse",
      "headline": "Start with the search, not the form.",
      "subtext": "Look around first. Make an account only if you want to keep going.",
      "hero_asset": "captures/auth/clinicalhours_auth_live_2026-05-29.png",
      "support_assets": []
    }
  ]
